---
import Layout from "../layouts/Layout.astro";
import headerLogo from "../assets/stamp-mizhu.png";
import contact from "../data/contact.json";
---

<Layout title="MIZHU – CONTACT" description="Contact MIZHU, director & VFX artist. Reach out via email or Instagram to discuss your project!">
	<h1 class="sr-only">Contact MIZHU, director & VFX artist</h1>
	<div class="content">
		<img src={headerLogo.src} alt="MIZHU" width={headerLogo.width} height={headerLogo.height} class="stamp" />
		<div class="contact">
			<span class="email" data-email={contact.email}>{contact.email}</span>
			<a href={contact.instagram.url} target="_blank" rel="noopener">Instagram</a>
		</div>
	</div>
</Layout>

<style>
	.stamp {
		width: 60vw;
		height: auto;
		display: block;
	}

	@media (min-width: 1024px) {
		.stamp {
			width: 15vw;
		}
	}

	.content {
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 2rem;
	}

	.contact {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
	}

	.contact span,
	.contact a {
		font-size: 1.5rem;
		font-weight: 500;
		line-height: 1;
		text-transform: uppercase;
		text-decoration: none;
	}

.email {
		cursor: pointer;
	}
</style>

<script>
	const el = document.querySelector<HTMLElement>('.email');
	const addr = el?.dataset.email;
	el?.addEventListener('click', async () => {
		if (!addr) return;
		await navigator.clipboard.writeText(addr);
		el.textContent = 'copied!';
		setTimeout(() => {
			el.textContent = addr;
		}, 1500);
	});
</script>
