---
interface Credit {
	role: string;
	names: { name: string; url?: string }[];
}

interface Project {
	slug: string;
	title: string;
	year: number;
	thumbnail: string;
	preview: string;
	videoUrl: string | null;
	credits: Credit[];
}

interface Props {
	projects: Project[];
}

const { projects } = Astro.props;
---

<section class="grid" data-nosnippet>
	{projects.map((project, i) => (
		<button
			class="card"
			data-title={project.title}
			data-year={project.year}
			data-video-url={project.videoUrl}
			data-preview={project.preview}
			data-credits={JSON.stringify(project.credits)}
		>
			<img
				src={project.thumbnail}
				alt={project.title}
				loading={i < 3 ? "eager" : "lazy"}
				fetchpriority={i < 3 ? "high" : undefined}
				onload="this.style.opacity=1"
			/>
			<video src={project.preview} muted loop playsinline preload="none" />
			<span class="card-title">{project.title}</span>
		</button>
	))}
</section>

<dialog id="project-modal">
	<button class="modal-close" aria-label="Close">&times;</button>
	<div class="modal-video">
		<iframe
			id="modal-iframe"
			width="100%"
			height="100%"
			style="border:0"
			allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
			allowfullscreen
		></iframe>
		<video id="modal-video" width="100%" height="100%" muted loop playsinline></video>
	</div>
	<h2 id="modal-title"></h2>
	<p id="modal-year"></p>
	<div id="modal-credits" class="credits"></div>
</dialog>

<style>
	.grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2.5rem;
		flex: 1;
		padding: 0 3rem;
	}

	@media (max-width: 1024px) {
		.grid {
			grid-template-columns: 1fr;
			gap: 1rem;
			padding: 0 0.5rem;
		}
	}

	.card {
		position: relative;
		background: #1a1a1a;
		border: none;
		padding: 0;
		cursor: pointer;
		overflow: hidden;
		aspect-ratio: 4 / 3;
		box-shadow: 3px 3px 6px rgba(0, 0, 0, 0.3);
	}


	.card::after {
		content: '';
		position: absolute;
		inset: 0;
		box-shadow:
			inset 2px 2px 4px rgba(255, 255, 255, 0.3),
			inset -2px -2px 4px rgba(0, 0, 0, 0.3);
		pointer-events: none;
	}

	.card img,
	.card video {
		width: 100%;
		height: 100%;
		object-fit: fill;
		display: block;
	}

	.card img {
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.card video {
		display: none;
		position: absolute;
		top: 0;
		left: 0;
	}

	.card-title {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		padding: 0.5rem;
		background: rgba(0, 0, 0, 0.6);
		color: #fff;
		font-size: 0.85rem;
		font-weight: 600;
		text-align: left;
		opacity: 0;
		transition: opacity 0.2s;
	}

	.card:hover .card-title,
	.card:focus .card-title {
		opacity: 1;
	}

	/* Modal */
	dialog {
		border: none;
		border-radius: 8px;
		margin: auto;
		padding: 0;
		width: min(90vw, 800px);
		max-height: 90vh;
		overflow-y: auto;
		background: #111;
		color: #fff;
	}

	dialog::backdrop {
		background: rgba(0, 0, 0, 0.7);
	}

	.modal-close {
		position: absolute;
		top: 0.5rem;
		right: 0.75rem;
		background: none;
		border: none;
		color: #fff;
		font-size: 1.75rem;
		cursor: pointer;
		z-index: 1;
		line-height: 1;
	}

	.modal-video {
		aspect-ratio: 16 / 9;
		width: 100%;
	}

	.modal-video iframe,
	.modal-video video {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	dialog h2 {
		margin: 1rem 1.25rem 0;
		font-size: 1.25rem;
	}

	dialog #modal-year {
		margin: 0.25rem 1.25rem 1.25rem;
		font-size: 0.85rem;
		opacity: 0.6;
	}

	.credits {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0 0.5rem;
		padding: 0 1.25rem 1.25rem;
		font-size: 0.85rem;
		line-height: 1.8;
	}

	.credits :global(.label) {
		text-align: right;
	}

	.credits :global(a) {
		color: var(--color-bg);
		text-decoration: none;
	}

	.credits :global(a:hover) {
		text-decoration: underline;
	}
</style>

<script>
	const cards = document.querySelectorAll<HTMLButtonElement>('.card');
	const dialog = document.getElementById('project-modal') as HTMLDialogElement;
	const modalVideo = dialog.querySelector('.modal-video') as HTMLDivElement;
	const iframe = document.getElementById('modal-iframe') as HTMLIFrameElement;
	const modalVideoEl = document.getElementById('modal-video') as HTMLVideoElement;
	const modalTitle = document.getElementById('modal-title')!;
	const modalYear = document.getElementById('modal-year')!;
	const modalCredits = document.getElementById('modal-credits')!;
	const closeBtn = dialog.querySelector('.modal-close')!;

	const isMobile = window.matchMedia('(max-width: 1024px)').matches;
	const pendingListeners = new Map<HTMLButtonElement, () => void>();

	function showPreview(card: HTMLButtonElement) {
		const img = card.querySelector('img')!;
		const video = card.querySelector('video')!;

		// readyState >= 3 (HAVE_FUTURE_DATA) means the video is already buffered from a previous play.
		// In that case, canplay won't fire again — swap immediately without waiting for it.
		if (video.readyState >= 3) {
			img.style.display = 'none';
			video.style.display = 'block';
			video.play();
			return;
		}

		const onCanPlay = () => {
			pendingListeners.delete(card);
			img.style.display = 'none';
			video.style.display = 'block';
		};

		pendingListeners.set(card, onCanPlay);
		video.addEventListener('canplay', onCanPlay, { once: true });
		video.play();
	}

	function hidePreview(card: HTMLButtonElement) {
		const img = card.querySelector('img')!;
		const video = card.querySelector('video')!;

		const pending = pendingListeners.get(card);
		if (pending) {
			video.removeEventListener('canplay', pending);
			pendingListeners.delete(card);
		}

		video.pause();
		video.currentTime = 0;
		video.style.display = 'none';
		img.style.display = 'block';
	}

	// Desktop: hover preview
	if (!isMobile) {
		cards.forEach((card) => {
			card.addEventListener('mouseenter', () => showPreview(card));
			card.addEventListener('mouseleave', () => hidePreview(card));
			card.addEventListener('focus', () => showPreview(card));
			card.addEventListener('blur', () => hidePreview(card));
		});
	}

	// Mobile: auto-play preview of centered card
	if (isMobile) {
		const observer = new IntersectionObserver((entries) => {
			for (const entry of entries) {
				const card = entry.target as HTMLButtonElement;
				if (entry.isIntersecting) {
					showPreview(card);
				} else {
					hidePreview(card);
				}
			}
		}, { rootMargin: '-40% 0px -40% 0px', threshold: 0 });

		cards.forEach((card) => observer.observe(card));
	}

	cards.forEach((card) => {

		// Click: open modal
		card.addEventListener('click', () => {
			const videoUrl = card.dataset.videoUrl;
			const title = card.dataset.title!;
			const year = card.dataset.year!;
			const credits = JSON.parse(card.dataset.credits!);

			if (videoUrl) {
				iframe.src = videoUrl.includes('?') ? `${videoUrl}&autoplay=1` : `${videoUrl}?autoplay=1`;
				iframe.style.display = '';
				modalVideoEl.style.display = 'none';
				modalVideoEl.src = '';
			} else {
				iframe.style.display = 'none';
				iframe.src = '';
				modalVideoEl.src = card.dataset.preview!;
				modalVideoEl.style.display = '';
				modalVideoEl.play();
			}
			modalVideo.style.display = '';

			modalTitle.textContent = title;
			modalYear.textContent = year;

			modalCredits.innerHTML = '';
			modalCredits.style.display = credits.length ? '' : 'none';
			for (const credit of credits) {
				const label = document.createElement('span');
				label.className = 'label';
				label.textContent = `${credit.role.toLowerCase()}:`;

				const value = document.createElement('span');
				value.innerHTML = credit.names
					.map((n: { name: string; url?: string }) =>
						n.url
							? `<a href="${n.url}" target="_blank" rel="noopener noreferrer">${n.name}</a>`
							: n.name
					)
					.join(' ');

				modalCredits.appendChild(label);
				modalCredits.appendChild(value);
			}

			dialog.showModal();
			(document.activeElement as HTMLElement)?.blur();
		});
	});

	// Close modal
	function closeModal() {
		dialog.close();
		iframe.src = '';
		modalVideoEl.pause();
		modalVideoEl.src = '';
	}

	closeBtn.addEventListener('click', closeModal);

	// Close on backdrop click
	dialog.addEventListener('click', (e) => {
		if (e.target === dialog) closeModal();
	});
</script>
